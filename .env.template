
## the BRAND variable is typically a predefined environment variable used to ensure consistent routing, user/path naming, or access control
## BRAND="magenx" - magenx/php-magenx, /opt/magenx/docker, /opt/magenx/magento/public
BRAND=""
## Magento shop domain name: domain.com
DOMAIN=""

## This value is prepended along with the service name to the container's name
## to simplify container registry branded location
COMPOSE_PROJECT_NAME="${BRAND}"

## Path configuration
## docker compose config in /opt/${BRAND}/docker
DOCKER_CONFIG_ROOT="/opt/${BRAND}"
CONTAINER_DATA_PATH="${DOCKER_CONFIG_ROOT}/data"
MAGENTO_ROOT_PATH="${DOCKER_CONFIG_ROOT}/magento"

## Symlink to production release
## /public is mouned to container, /current is symlink
CURRENT_SYMLINK="public/current"

## Container health checks
HEALTHCHECK_START_PERIOD="30s"
HEALTHCHECK_INTERVAL="30s"
HEALTHCHECK_TIMEOUT="10s"
HEALTHCHECK_RETRIES="3"

## Magento config variables
CRYPT_KEY=""
GRAPHQL_ID_SALT=""
TIMEZONE="Europe/Berlin"
MAGENTO_UID="1000"

## Composer variables
COMPOSER_AUTH='{"http-basic": {"repo.magento.com": {"username": "8c681734f22763b50ea0c29dff9e7af2","password": "02dfee497e669b5db1fe1c8d481d6974"}}}'
